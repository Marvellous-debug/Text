import random
import time


# Selection Sort
def selection_sort(numbers):

    loops = 0
    comparisons = 0
    shifts = 0

    for i in range(len(numbers)):
        loops += 1

        min_index = i

        for j in range(i + 1, len(numbers)):
            loops += 1
            comparisons += 1

            if numbers[j] < numbers[min_index]:
                min_index = j

        if min_index != i:
            numbers[i], numbers[min_index] = numbers[min_index], numbers[i]
            shifts += 1

    return loops, comparisons, shifts


# Bubble Sort
def bubble_sort(numbers):

    loops = 0
    comparisons = 0
    shifts = 0

    for i in range(len(numbers)):
        loops += 1

        for j in range(len(numbers) - i - 1):
            loops += 1
            comparisons += 1

            if numbers[j] > numbers[j + 1]:
                numbers[j], numbers[j + 1] = numbers[j + 1], numbers[j]
                shifts += 1

    return loops, comparisons, shifts


# Insertion Sort
def insertion_sort(numbers):

    loops = 0
    comparisons = 0
    shifts = 0

    for i in range(1, len(numbers)):
        loops += 1

        current = numbers[i]
        j = i - 1

        while j >= 0:
            loops += 1
            comparisons += 1

            if numbers[j] > current:
                numbers[j + 1] = numbers[j]
                shifts += 1
                j -= 1
            else:
                break

        numbers[j + 1] = current

    return loops, comparisons, shifts


# Quick Sort
def quick_sort(numbers):

    comparisons = 0
    loops = 0
    shifts = 0

    def quick(arr):
        nonlocal comparisons, loops, shifts

        if len(arr) <= 1:
            return arr

        pivot = arr[len(arr) // 2]

        left = []
        middle = []
        right = []

        for value in arr:
            loops += 1
            comparisons += 1

            if value < pivot:
                left.append(value)
                shifts += 1

            elif value > pivot:
                right.append(value)
                shifts += 1

            else:
                middle.append(value)
                shifts += 1

        return quick(left) + middle + quick(right)

    sorted_list = quick(numbers)

    return sorted_list, loops, comparisons, shifts


