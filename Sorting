import random


# Selection Sort
def selection_sort(numbers, ascending):

    for i in range(len(numbers)):

        min_max_index = i

        for j in range(i + 1, len(numbers)):

            if ascending:
                if numbers[j] < numbers[min_max_index]:
                    min_max_index = j
            else:
                if numbers[j] > numbers[min_max_index]:
                    min_max_index = j

        numbers[i], numbers[min_max_index] = numbers[min_max_index], numbers[i]


# Bubble Sort
def bubble_sort(numbers, ascending):

    for i in range(len(numbers)):

        for j in range(0, len(numbers) - i - 1):

            if ascending:
                if numbers[j] > numbers[j + 1]:
                    numbers[j], numbers[j + 1] = numbers[j + 1], numbers[j]

            else:
                if numbers[j] < numbers[j + 1]:
                    numbers[j], numbers[j + 1] = numbers[j + 1], numbers[j]


# Insertion Sort
def insertion_sort(numbers, ascending):

    for i in range(1, len(numbers)):

        current = numbers[i]
        j = i - 1

        if ascending:
            while j >= 0 and numbers[j] > current:
                numbers[j + 1] = numbers[j]
                j -= 1

        else:
            while j >= 0 and numbers[j] < current:
                numbers[j + 1] = numbers[j]
                j -= 1

        numbers[j + 1] = current


# Quick Sort
def quick_sort(numbers, ascending):

    if len(numbers) <= 1:
        return numbers

    pivot = numbers[len(numbers) // 2]

    if ascending:
        left = [x for x in numbers if x < pivot]
        middle = [x for x in numbers if x == pivot]
        right = [x for x in numbers if x > pivot]

    else:
        left = [x for x in numbers if x > pivot]
        middle = [x for x in numbers if x == pivot]
        right = [x for x in numbers if x < pivot]

    return quick_sort(left, ascending) + middle + quick_sort(right, ascending)


# User input
amount = int(input("How many numbers do you want in the list? "))

print("\nSorting Algorithms:")
print("1. Selection Sort")
print("2. Bubble Sort")
print("3. Insertion Sort")
print("4. Quick Sort")

choice = int(input("Choose a sorting algorithm (1-4): "))

order = input("Ascending or Descending? ").lower()

ascending = True

if order == "descending":
    ascending = False


# Generate random numbers
numbers = []

for i in range(amount):
    numbers.append(random.randint(0, 1000))


# Display unsorted list
print("\nUnsorted List:")
print(numbers)


# Perform selected sort
if choice == 1:
    selection_sort(numbers, ascending)

elif choice == 2:
    bubble_sort(numbers, ascending)

elif choice == 3:
    insertion_sort(numbers, ascending)

elif choice == 4:
    numbers = quick_sort(numbers, ascending)

else:
    print("Invalid choice.")


# Display sorted list
print("\nSorted List:")
print(numbers)
